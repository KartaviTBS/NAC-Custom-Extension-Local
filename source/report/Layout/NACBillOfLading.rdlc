                                                <Style>
                                                  <FontSize>8pt</FontSize>
                                                  <TextDecoration>Underline</TextDecoration>
                                                </Style>
                                              </TextRun>
                                              <TextRun>
                                                <Value>=Sum(Fields!perOrderTotalValue.Value)</Value>
                                                <Style>
