                                          <Paragraph>
                                            <TextRuns>
                                              <TextRun>
                                                <Value>Where the rate is dependent on value, shippers are required to state specifically in writing the agreed or declared value of the property as follows:</Value>
                                                <Style>
                                                  <FontSize>8pt</FontSize>
                                                </Style>
                                              </TextRun>
                                            </TextRuns>
